---
layout: layouts/basic.njk
title: Generate Agreement Link
---

<div class="max-w-2xl mx-auto px-4 py-8 text-gray-800">
	<h1 class="text-3xl font-bold mb-6 text-center">Generate Agreement Link</h1>

	<form id="linkForm" class="space-y-4 bg-white p-6 rounded shadow">
		<div>
			<label class="block text-sm font-medium mb-1">Guest Name</label>
			<input type="text" name="guestName" required
						 class="w-full px-3 py-2 border border-gray-300 rounded">
		</div>

		<div>
			<label class="block text-sm font-medium mb-1">Property Address</label>
			<input type="text" name="address" value="8329 E Weldon Ave, Scottsdale, AZ 85251"
						 class="w-full px-3 py-2 border border-gray-300 rounded">
		</div>

		<div>
			<label class="block text-sm font-medium mb-1">Arrival Date</label>
			<input type="date" name="arrivalDate" required
						 class="w-full px-3 py-2 border border-gray-300 rounded">
		</div>

		<div>
			<label class="block text-sm font-medium mb-1">Number of Days</label>
			<input type="number" name="numDays" min="1" value="2" required
						 class="w-full px-3 py-2 border border-gray-300 rounded">
		</div>

		<div>
			<label class="block text-sm font-medium mb-1">Daily Rate (USD)</label>
			<input type="number" name="dailyRate" min="0" step="0.01" value="375.00" required
						 class="w-full px-3 py-2 border border-gray-300 rounded">
		</div>

		<div>
			<label class="block text-sm font-medium mb-1">Cleaning Fee (USD)</label>
			<input type="number" name="cleaningFee" min="0" step="0.01" value="150.00" required
						 class="w-full px-3 py-2 border border-gray-300 rounded">
		</div>

		<div class="flex gap-6">
			<label class="flex items-center gap-2">
				<input type="checkbox" name="hasPool" checked> Pool
			</label>
			<label class="flex items-center gap-2">
				<input type="checkbox" name="hasSpa"> Spa
			</label>
		</div>

		<div>
			<label class="block text-sm font-medium mb-2">Additional Guests</label>
			<div id="additionalGuests" class="space-y-2"></div>
			<button type="button" id="addGuestBtn"
							class="mt-2 px-3 py-1 text-sm bg-gray-200 rounded hover:bg-gray-300">
				+ Add Guest
			</button>
		</div>

		<button type="submit"
						class="w-full py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
			Generate Link
		</button>
	</form>

	<div id="result" class="mt-6 hidden">
		<label class="block text-sm font-medium mb-1">Generated Link</label>
		<div class="flex gap-2">
			<input type="text" id="resultLink" readonly
						 class="flex-1 px-3 py-2 border border-gray-300 rounded bg-gray-50 text-sm">
			<button type="button" id="copyBtn"
							class="px-4 py-2 bg-gray-700 text-white rounded hover:bg-gray-800">Copy</button>
		</div>
		<a id="openLink" href="#" target="_blank"
			 class="inline-block mt-2 text-blue-600 hover:underline text-sm">Open in new tab →</a>
	</div>
</div>

<script>
	const relations = ['Spouse', 'Child', 'Family Member', 'Friend'];
	const additionalGuestsEl = document.getElementById('additionalGuests');

	function addGuestRow() {
		const row = document.createElement('div');
		row.className = 'flex gap-2 guest-row';
		row.innerHTML = `
			<input type="text" placeholder="Name" class="flex-1 px-3 py-2 border border-gray-300 rounded guest-name">
			<select class="px-3 py-2 border border-gray-300 rounded guest-relation">
				<option value="">Relation</option>
				${relations.map(r => `<option value="${r}">${r}</option>`).join('')}
			</select>
			<button type="button" class="px-3 py-2 bg-red-100 text-red-700 rounded remove-btn">×</button>
		`;
		row.querySelector('.remove-btn').addEventListener('click', () => row.remove());
		additionalGuestsEl.appendChild(row);
	}

	document.getElementById('addGuestBtn').addEventListener('click', addGuestRow);

	document.getElementById('linkForm').addEventListener('submit', function (e) {
		e.preventDefault();
		const fd = new FormData(this);

		// Convert YYYY-MM-DD -> MM/DD/YYYY
		const [y, m, d] = fd.get('arrivalDate').split('-');
		const arrivalDate = `${m}/${d}/${y}`;

		const additionalGuests = [];
		document.querySelectorAll('.guest-row').forEach(row => {
			const name = row.querySelector('.guest-name').value.trim();
			const relation = row.querySelector('.guest-relation').value;
			if (name && relation) additionalGuests.push({ name, relation });
		});

		const params = new URLSearchParams({
			guestName: fd.get('guestName'),
			address: fd.get('address'),
			arrivalDate,
			numDays: fd.get('numDays'),
			dailyRate: fd.get('dailyRate'),
			cleaningFee: fd.get('cleaningFee'),
			hasPool: fd.get('hasPool') ? 'true' : 'false',
			hasSpa: fd.get('hasSpa') ? 'true' : 'false',
		});
		if (additionalGuests.length) {
			params.set('additionalGuests', JSON.stringify(additionalGuests));
		}

		const url = `${window.location.origin}/agreement/?${params.toString()}`;
		document.getElementById('resultLink').value = url;
		document.getElementById('openLink').href = url;
		document.getElementById('result').classList.remove('hidden');
	});

	document.getElementById('copyBtn').addEventListener('click', function () {
		const input = document.getElementById('resultLink');
		input.select();
		navigator.clipboard.writeText(input.value);
		this.textContent = 'Copied!';
		setTimeout(() => (this.textContent = 'Copy'), 1500);
	});
</script>
